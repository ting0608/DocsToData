OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
VECTOR_DIM=1536

# Ollama local models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_VECTOR_DIM=768

# Set to true on Google Cloud Run (OpenAI-only). Omit or false locally to use Ollama.
DISABLE_OLLAMA=false

# Optional: enable persistent storage in Google Cloud Storage.
# When set, uploads and FAISS index files are mirrored to this bucket.
GCS_BUCKET=
GCS_PREFIX=docstodata
